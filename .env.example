# FastAPI REST API - Environment Configuration
# Copia este archivo a .env y configura los valores

# Servidor
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# CORS (separados por coma, o "*" para permitir todos)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# API
API_TITLE=FastAPI REST API
API_VERSION=1.1.0
